mdhn:Shahnameh a mdhn:LiteraryEpicWork , owl:NamedIndividual ;
    mdhn:aatConcept aat:300404209 ;
    mdhn:wikidataItem wd:Q8279 ;
    dcterms:created "c. 1010" ;
    rdfs:comment """The Shahnameh, or Book of Kings, is an epic poem written by the Persian poet Ferdowsi around 1010 CE. It is one of the most important works of Persian literature and tells the mythical and historical past of Persia from the creation of the world until the Islamic conquest in the 7th century."""@en ;
    rdfs:label "Shahnameh"@en , "شاهنامه"@fa .

mdhn:manuscript_shahnama_shah_tahmasp a mdhn:Manuscript , owl:NamedIndividual ;
    mdhn:aatConcept aat:300028569 ;
    mdhn:hasOwnershipInterval mdhn:houghton_collection , mdhn:ottoman_topkapi , mdhn:safavid_library ;
    mdhn:hasPaintingRegister mdhn:painting_Index ;
    mdhn:wikidataItem wd:Q3114572;
    dcterms:created "1522/1535" ;
    rdfs:comment """The Houghton Shahnama. Royal Persian manuscript produced 
    c. 1522-1535 CE in Tabriz under Shah Tahmasp I. Contains 268 full-page paintings. 
    Now dispersed across 30+ collections."""@en ;
    rdfs:label "Shahnama of Shah Tahmasp"@en , "شاهنامه شاه طهماسپ"@fa ;
    skos:related wd:Q64675957 .


