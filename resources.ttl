                      mdhn:UnsuriFig7r,
                      mdhn:AsjadiFig7r;
  mdhn:hasReferredTo  mdhn:Firdowsi,
                      mdhn:AbuMansurDaqiqi,
                      mdhn:Unsuri,
                      mdhn:Asjadi;                     
   mdhn:hasWorkshop_director  mdhn:Aqa_Mīrak ;
   mdhn:wikidataItem wd:Q64689329 ;
   mdhn:attributionCertainty "probable"@en;
   mdhn:hasPainter mdhn:Aqa_Mīrak .  

mdhn:FirdowsiFig7r a mdhn:FigureCrop;
