# -- Folio 20v -----------------------------------------------------
mdhn:RE_20v a mdhn:RegisterEntry;
    rdfs:label "The Court of Kayumars"@en, "پادشاهی کيومرث"@fa;
    rdfs:comment "According to Firdausi, the very idea of kingship originated with King Kayumars, who ruled for thirty years, overseeing a peaceable kingdom in which men wore leopard-skin robes and wild animals grew tame. In this utopia Kayumars had one secret enemy, the evil Ahriman, whose envy drove him to incite his own son, the Black Div, to murder Siyamak, the son of Kayumars. Before the assassination took place, the angel Surush warned Kayumars of Ahriman’s plot"@en;
    mdhn:entryFolioNumber "20v";
    mdhn:entryPartOf mdhn:painting_Index. 

mdhn:Folio20v a mdhn:Verso;
   mdhn:isFolioOf mdhn:manuscript_shahnama_shah_tahmasp;
   mdhn:nextFolio mdhn:Folio21v ;
   mdhn:keptIn mdhn:Aga_Khan_Museum;
   mdhn:hasContentElement mdhn:Painting20v, mdhn:Poems20v;  
   mdhn:hasIIIFManifest "https://iiif.archive.org/iiif/3/shahnama-shah-tahmasp-20v/manifest.json"; 
   mdhn:hasRegisterEntry mdhn:RE_20v.

mdhn:Painting20v a mdhn:Painting;
   mdhn:hasFigureCrop mdhn:KeyumarsFig20v, mdhn:SiamakFig20v ;
   mdhn:hasNarrativeEpisode mdhn:TahmurasDefeatsKingdomOfKeyumars;
   mdhn:hasReferredTo mdhn:Keyumars, mdhn:Siamak, mdhn:BlackDiv;
   mdhn:hasWorkshop_director  mdhn:Sultan_Muhammad ;
   mdhn:wikidataItem wd:Q64689329 ;
   mdhn:attributionCertainty "certain"@en;
   mdhn:hasPainter mdhn:Sultan_Muhammad .

mdhn:TahmurasDefeatsKingdomOfKeyumars a mdhn:NarrativeEpisode;
   mdhn:wikidataItem wd:Q138719971 .  

mdhn:Poems20v a mdhn:LinguisticObject;
  mdhn:startVerse "75";
  mdhn:endVerse "85".

mdhn:KeyumarsFig20v a mdhn:FigureCrop;
   rdfs:label "Keyumars cropped figure from f20v"@en;
   mdhn:hasReferredTo mdhn:Keyumars;   
   mdhn:iiifRegionURL "https://iiif.archive.org/image/iiif/3/shahnama-shah-tahmasp-20v%2F20v.jpg/332,517,120,165/max/0/default.jpg". 

mdhn:SiamakFig20v a mdhn:FigureCrop;
   rdfs:label "Siamak cropped figure from f20v"@en;
   mdhn:hasReferredTo mdhn:Siamak;   
   mdhn:iiifRegionURL "https://iiif.archive.org/image/iiif/3/shahnama-shah-tahmasp-20v%2F20v.jpg/489,642,106,133/max/0/default.jpg". 

# -- Folio 21v -----------------------------------------------------
mdhn:RE_21v a mdhn:RegisterEntry;
    rdfs:label "Hushang Slavs the Black Div"@en, "کشته شدن ديو سياه به دست هوشنگ"@fa;
    rdfs:comment "On the orders of his grandfather Hushang avenges the murder of his father, Siyamak, and wages war against Ahriman and his dirs (demons) with an army of lions, wolves, leopards, and angels."@en;
    mdhn:entryFolioNumber "21v";
    mdhn:entryPartOf mdhn:painting_Index.

mdhn:Folio21v a mdhn:Verso;
   mdhn:isFolioOf mdhn:manuscript_shahnama_shah_tahmasp;
   mdhn:nextFolio mdhn:Folio22v ;
   mdhn:keptIn mdhn:S_C_Welch_Family_Collection;
   mdhn:hasContentElement mdhn:Painting21v, mdhn:Poems21v; 
   mdhn:wikidataItem wd:Q131281679; 
   mdhn:hasIIIFManifest "https://iiif.archive.org/iiif/3/shahnama-shah-tahmasp-21v/manifest.json"; 
