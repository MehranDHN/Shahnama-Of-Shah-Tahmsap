# -- Folio 102v -----------------------------------------------------
mdhn:RE_102v a mdhn:RegisterEntry;
    rdfs:label "Qaran Slays Barman"@en, "کشته شدن بارمان به دست قاران"@fa;
    rdfs:comment "Several battles follow the death of Qubad, cach one successively worse, Eventually, the Iranians flee to a castle, where the Turanians besiege them. In defiance of Shah Nauzar, Qaran, the commander of the Iranian army and Qubad\'s brother, and a group of like minded troops sneak out of their fortress to rescue their families in Iran. However, they encounter Barman, the murderer of Qubad. Qaran gives chase until he spears the Turanian and beheads him."@en;
    mdhn:entryFolioNumber "102v";
    mdhn:entryPartOf mdhn:painting_Index.  

mdhn:Folio102v a mdhn:Verso;
   rdfs:label "Folio 102v"@en;
