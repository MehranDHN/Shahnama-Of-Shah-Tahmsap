# -- Folio 77v -----------------------------------------------------
mdhn:RE_77v a mdhn:RegisterEntry;
    rdfs:label "Mihrab Hears of Rudaba Folly"@en, "رودابه در مورد زال در نزد مادر خود اعتراف می کند"@fa;
    rdfs:comment "Mihrab comes to Sindukht's chamber, where she speaks poetically of death and the passage of time. She then tells him that Rudaba has lost her heart to Zal, prompting Mihrab to threaten to kill his daughter. Sindukht manages to calm him, but Mihrab worries that Manuchihr will never consent to this marriage."@en;
    mdhn:entryFolioNumber "77v";
    mdhn:entryPartOf mdhn:painting_Index. 

