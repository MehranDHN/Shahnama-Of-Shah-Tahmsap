# -- Folio 25v -----------------------------------------------------
mdhn:RE_25v a mdhn:RegisterEntry;
    rdfs:label "The Death of King Mirdas"@en, "کشته شدن مرداس"@fa;
    rdfs:comment "The just king of Arabia, Mirdas(Mardas), has an ambitious son, Zahhak, who joins Iblis (Satan) in a plot to kill his father. Iblis orders a pit dug on the palace grounds, and when Mirdas seeks seclusion in the garden in the middle of the night, he falls into the pit and dies. "@en;
    mdhn:entryFolioNumber "25v";
    mdhn:entryPartOf mdhn:painting_Index.  

