  mdhn:endVerse 3791.

mdhn:QaranFig102v a mdhn:FigureCrop;
   rdfs:label "Qaran cropped figure from f102v"@en;
   mdhn:hasReferredTo mdhn:Qaran;
   mdhn:iiifRegionURL "https://iiif.archive.org/image/iiif/3/shahnama-shah-tahmasp-102v%2FFolio102v.jpeg/647,1997,724,675/max/0/default.jpg".

mdhn:BarmanFig102v a mdhn:FigureCrop;
   rdfs:label "Barman cropped figure from f102v"@en;
   mdhn:hasReferredTo mdhn:Barman;
   mdhn:iiifRegionURL "https://iiif.archive.org/image/iiif/3/shahnama-shah-tahmasp-102v%2FFolio102v.jpeg/1189,2209,891,531/max/0/default.jpg".

mdhn:BattleZoomScene102v a mdhn:ZoomedScene;
   rdfs:label "Battle zoom scene cropped figure from f102v"@en;
   mdhn:hasReferredTo mdhn:Qaran, mdhn:Barman;
   rdfs:comment "This battle scene, with its eerie nocturnal palette, is the last picture in the sequence of the manuscript that can be assigned to Sultan Muhammad, and it would seem that he was assisted in coloring it by a younger artist, Mir Sayyid Ali, one of the masters of the second generation. The hand of the younger man is evident in the treatment of many of the faces, also in the treatment of some of the horses and their trappings. While Sultan Muhammad invariably gave his characters life, the younger man, who was a brilliant designer and an almost miraculously fine craftsman, painted people and animals as still life. Later, Mir Sayyid AH went to India and became one of the founders of the Mughal school of painting"@en;
   mdhn:iiifRegionURL "https://iiif.archive.org/image/iiif/3/AKingsBookofKingsTheShahnamehofShahTahmasp%2FAKingsBookofKingsTheShahnamehofShahTahmasp_jp2.zip%2FAKingsBookofKingsTheShahnamehofShahTahmasp_jp2%2FAKingsBookofKingsTheShahnamehofShahTahmasp_0138.jp2/full/max/0/default.jpg".

