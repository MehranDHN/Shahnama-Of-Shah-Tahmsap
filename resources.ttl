# -- Folio 2v -----------------------------------------------------
mdhn:RE_2v a mdhn:RegisterEntry;
    rdfs:label "Left side of Doble page Illuminated frontispece"@en, "رويارويی فردوسی با شعرای دربار غزنه"@fa;
    rdfs:comment "Left side opening illuminated page"@en;
    mdhn:entryFolioNumber "2v";
    mdhn:entryPartOf mdhn:painting_Index.

mdhn:Folio2v a mdhn:Verso;
   rdfs:label "Folio 2v"@en ;
   mdhn:isFolioOf mdhn:manuscript_shahnama_shah_tahmasp;
   mdhn:nextFolio mdhn:Folio3r ;
   mdhn:folioNumber 2 ;
   mdhn:keptIn mdhn:Tehran_Museum_of_Contemporary_Art;
   mdhn:hasContentElement mdhn:Illumination2v, mdhn:ProseText2v;  
   mdhn:hasIIIFManifest "https://iiif.archive.org/iiif/3/shahnama-shah-tahmasp-2v/manifest.json"; 
   mdhn:hasRegisterEntry mdhn:RE_2v.  

mdhn:Illumination2v a mdhn:Painting;                   
   mdhn:hasWorkshop_director  mdhn:Aqa_Mīrak ;
   mdhn:attributionCertainty "probable"@en;
   mdhn:hasIlluminator mdhn:Aqa_Mīrak .  

mdhn:ProseText2v a mdhn:LinguisticObject;
  rdfs:label "Plain text and poems in left side of double page opening from 2v"@en.  

