   mdhn:wikidataItem wd:Q64690773; 
   mdhn:hasIIIFManifest "https://iiif.archive.org/iiif/3/shahnama-shah-tahmasp-102v/manifest.json"; 
   mdhn:hasRegisterEntry mdhn:RE_102v.  

mdhn:Painting102v a mdhn:Painting;
   mdhn:hasFigureCrop mdhn:QaranFig102v, mdhn:BarmanFig102v;
   mdhn:hasNarrativeEpisode mdhn:Qaran_Slays_Barman;
