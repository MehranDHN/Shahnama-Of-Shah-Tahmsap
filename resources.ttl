   # -- Folio 339r -----------------------------------------------------
mdhn:RE_339r a mdhn:RegisterEntry;
    rdfs:label "Planning for the Joust of the Twelve Rooks"@en, "توافق بر نبرد دوازده رخ"@fa;
    rdfs:comment "In reaction to the stalemate between their armies, Gudarz and Piran hold a parlev and agree on a series of eleven jousts to decide the winner of the war. In cach camp the commanders choose the ten champions who, in addition to themselves, will oust. As a venue, they select a field between two mounds so that the winners can plant their flags on their respective peaks "@en;
    mdhn:entryFolioNumber "339r";
    mdhn:entryPartOf mdhn:painting_Index.  

