# -- Folio 76v -----------------------------------------------------
mdhn:RE_76v a mdhn:RegisterEntry;
    rdfs:label "Rudaba Confesses to Sindukht"@en, "رودابه در مورد زال در نزد مادر خود اعتراف می کند"@fa;
    rdfs:comment "After noticing the comings and goings of the woman who delivers the message that Sam consents to Zal and. Ruclaba's marriage, Sindukht falls into a fury, expecting the worst of her daughter. Then Rudaba confesses her love for Zal and announces that Sam has agreed to their union. Sindukht relents and begins plotting how to tell Mihrab and Manuchihr."@en;
    mdhn:entryFolioNumber "76v";
    mdhn:entryPartOf mdhn:painting_Index. 

