    rdfs:label "Left side of Doble page Illuminated frontispece"@en, "رويارويی فردوسی با شعرای دربار غزنه"@fa;
    rdfs:comment "Left side opening illuminated page"@en;
    mdhn:entryFolioNumber "2v";
    mdhn:entryPartOf mdhn:painting_Index.

mdhn:Folio2v a mdhn:Verso;
   mdhn:isFolioOf mdhn:manuscript_shahnama_shah_tahmasp;
   mdhn:nextFolio mdhn:Folio3r ;
   mdhn:keptIn mdhn:Tehran_Museum_of_Contemporary_Art;
   mdhn:hasContentElement mdhn:Illumination2v, mdhn:ProseText2v;  
