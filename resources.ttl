    # -- Folio 342r -----------------------------------------------------
mdhn:RE_342r a mdhn:RegisterEntry;
    rdfs:label "The Fourth 'Joust of the Rooks': Faruhil versus Zangula"@en, "رويارويی چهارم فرهول و زنگله"@fa;
    rdfs:comment "The fourth joust features Faruhil, an Iranian champion known for his skill with the bow, against the Turanian Zangula. After peppering Zangula with arrows, Karuhil shoots one that hits both Zangula and his horse, which falls forward, throwing its rider. Zangula falls on his head and dies instantly "@en;
    mdhn:entryFolioNumber "342r";
    mdhn:entryPartOf mdhn:painting_Index.  

