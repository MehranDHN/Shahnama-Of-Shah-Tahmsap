mdhn:manuscript_shahnama_shah_tahmasp a mdhn:Manuscript , owl:NamedIndividual ;
    mdhn:aatConcept aat:300028569 ;
    mdhn:hasOwnershipInterval mdhn:houghton_collection , mdhn:ottoman_topkapi , mdhn:safavid_library ;
    mdhn:hasPaintingRegister mdhn:painting_Index ;
    mdhn:wikidataItem wd:Q3114572, wd:Q64675957 ;
    dcterms:created "1522/1535" ;
    rdfs:comment """The Houghton Shahnama. Royal Persian manuscript produced 
    c. 1522-1535 CE in Tabriz under Shah Tahmasp I. Contains 268 full-page paintings. 
    Now dispersed across 30+ collections."""@en ;
    rdfs:label "Shahnama of Shah Tahmasp"@en , "شاهنامه شاه طهماسپ"@fa ;
    skos:related wd:Q8279 .

mdhn:gift         a mdhn:TransferType ; rdfs:label "Gift"@en , "هدیه"@fa .
mdhn:purchase     a mdhn:TransferType ; rdfs:label "Purchase"@en , "خرید"@fa .
mdhn:auction      a mdhn:TransferType ; rdfs:label "Auction"@en , "حراج"@fa .
mdhn:confiscation a mdhn:TransferType ; rdfs:label "Confiscation"@en , "مصادره"@fa .
mdhn:bequest      a mdhn:TransferType ; rdfs:label "Bequest"@en , "وصیت"@fa .
mdhn:dispersal    a mdhn:TransferType ; rdfs:label "Dispersal (folio removal)"@en , "جداسازی برگ"@fa .
mdhn:deposit      a mdhn:TransferType ; rdfs:label "Deposit / Loan"@en , "امانت"@fa .       

mdhn:painting_Index a mdhn:PaintingRegister ;
    mdhn:registerFor mdhn:manuscript_shahnama_shah_tahmasp ;
    dcterms:description """Complete checklist of the 268 identified paintings. 
    Each entry links to a folio resource if the painting is located and digitised, 
    or remains unlinked if the painting is missing or unaccounted for."""@en ;
    dcterms:source "Dickson, Martin B. and Welch, Stuart Cary. The Houghton Shahnameh. 1981."@en ;
    rdfs:label "Authoritative register of 268 paintings — Shahnama of Shah Tahmasp"@en , "فهرست معتبر ۲۶۸ نگاره — شاهنامه شاه طهماسپ"@fa .    

mdhn:safavid_library
    a mdhn:OwnershipInterval ;
    rdfs:label        "Safavid Royal Library (Tabriz / Qazvin)"@en ;
    mdhn:owner        mdhn:shah_tahmasp ;
    mdhn:ownershipStart "1522"^^xsd:gYear ;
    mdhn:ownershipEnd   "1568"^^xsd:gYear ;
    mdhn:transferType   mdhn:gift ;
    rdfs:comment  "Gifted to Ottoman Sultan Selim II in 1568."@en .

mdhn:ottoman_topkapi
    a mdhn:OwnershipInterval ;
    rdfs:label        "Topkapi Palace Library"@en ;
    mdhn:owner        mdhn:sultan_selim_ii ;
    mdhn:ownershipStart "1568"^^xsd:gYear ;
    mdhn:ownershipEnd   "1903"^^xsd:gYear ;
    mdhn:transferType   mdhn:gift ;
    rdfs:comment  "Held in Topkapı. Ottoman annotations added during this period."@en .

mdhn:houghton_collection
    a mdhn:OwnershipInterval ;
    rdfs:label        "Arthur A. Houghton Jr. collection"@en ;
    mdhn:owner        mdhn:arthur_houghton ;
    mdhn:ownershipStart "1959"^^xsd:gYear ;
    mdhn:ownershipEnd   "1972"^^xsd:gYear ;
    mdhn:transferType   mdhn:purchase ;
    rdfs:comment  "Purchased; 78 folios donated to the Metropolitan Museum of Art; remainder sold."@en .

