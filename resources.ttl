   rdfs:label "Qaran Slays Barman"@en, "کشته شدن بارمان به دست قاران"@fa;
   mdhn:wikidataItem wd:Q138847591 . 

   # -- Folio 299r -----------------------------------------------------
mdhn:RE_299r a mdhn:RegisterEntry;
    rdfs:label "Bizhan Slaughters the Wild Boars of Irman"@en, "کشته شدن گرازهای وحشی به دست بيژن"@fa;
    rdfs:comment "In the remote land of Irman, a herd of enormous wild boars is destroying, fields and flocks. A delegation seeks the help of Kay Khusrau, who offers a reward to the paladin who can rid Irman of this scourge. Young Bizhan eagerly takes up the challenge and departs with Gurgin as his guide. Singlehandedly he pursues the boars in the forest, slicing in two the head of one and intimidating the rest. Thus, Bizhan easily puts them to the sword."@en;
    mdhn:entryFolioNumber "299r";
    mdhn:entryPartOf mdhn:painting_Index.  

