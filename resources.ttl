# -- Folio 22v -----------------------------------------------------
mdhn:RE_22v a mdhn:RegisterEntry;
    rdfs:label "The Feast of Sada"@en, "جشن سده"@fa;
    rdfs:comment "Hushang succeeds Keyumars and presides over the development of metalworking and animal husbandry. When he throws a rock, striking a boulder, and sparks turn to flame, he recognizes fire as a divine gilt and initiates the feast of Sada to celebrate this discovery."@en;
    mdhn:entryFolioNumber "22v";
    mdhn:entryPartOf mdhn:painting_Index.

mdhn:Folio22v a mdhn:Verso;
   rdfs:label "Folio 22v"@en;
   mdhn:isFolioOf mdhn:manuscript_shahnama_shah_tahmasp;
   mdhn:nextFolio mdhn:Folio23v ;
   mdhn:folioNumber 22;
   mdhn:keptIn mdhn:Metropolitan_Museum_of_Art;
   mdhn:hasOwnershipInterval mdhn:MetropolitanMuseumofArt;
   mdhn:hasContentElement mdhn:Painting22v, mdhn:Poems22v; 
   mdhn:wikidataItem wd:Q29385197; 
   mdhn:hasIIIFManifest "https://iiif.archive.org/iiif/3/shahnama-shah-tahmasp-22v/manifest.json"; 
   mdhn:hasRegisterEntry mdhn:RE_22v.  

