# -- Folio 7r -----------------------------------------------------
mdhn:RE_7r a mdhn:RegisterEntry;
    rdfs:label "Firdausi Encounters the Court Poets of Ghazua"@en, "رويارويی فردوسی با شعرای دربار غزنه"@fa;
    rdfs:comment "On his way to seek the patronage of Sultan Mahmud of Ghazna for the Shabana, Firdausi encounters three of the sultan\'s poets, who test his poctic skills before allowing him to join them"@en;
    mdhn:entryFolioNumber "7r";
    mdhn:entryPartOf mdhn:painting_Index.

mdhn:Folio7r a mdhn:Recto;
   rdfs:label "Folio 7r"@en ;
   mdhn:isFolioOf mdhn:manuscript_shahnama_shah_tahmasp;
   mdhn:nextFolio mdhn:Folio10r ;
   mdhn:folioNumber 7 ;
   mdhn:keptIn mdhn:Aga_Khan_Museum;
   mdhn:hasContentElement mdhn:Painting7r, mdhn:ProseText7r;  
   mdhn:hasIIIFManifest "https://iiif.archive.org/iiif/3/shahnama-shah-tahmasp-7r/manifest.json"; 
   mdhn:hasRegisterEntry mdhn:RE_7r.  

mdhn:Painting7r a mdhn:Painting;
   mdhn:hasFigureCrop mdhn:FirdowsiFig7r ,
