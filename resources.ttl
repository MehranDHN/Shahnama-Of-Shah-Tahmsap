   # -- Folio 341v -----------------------------------------------------
mdhn:RE_341v a mdhn:RegisterEntry;
    rdfs:label "The First 'Joust of the Rooks': Fariburz versus Kalbad"@en, "رويارويی اول فريبرز و کلباد"@fa;
    rdfs:comment "The first rivals are Fariburz, uncle of Kay Khusrau, and Kalbad, brother of Piram When the arrows Fariburz shoots at his foe miss their mark, he draws his sword and slices Kalbad in two, from neck to waist. He then ascends the mound and places the first Iranian flag on it"@en;
    mdhn:entryFolioNumber "341v";
    mdhn:entryPartOf mdhn:painting_Index.  

